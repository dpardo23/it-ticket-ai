{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "IT_Ticket_AI",
    "version": "0.1.0",
    "identifier": "com.umss.itticketai",
    "build": {
        "frontendDist": "../out",
        "devUrl": "http://localhost:3000",
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build"
    },
    "app": {
        "windows": [
            {
                "title": "IT Ticket AI",
                "width": 1200,
                "height": 800,
                "resizable": true,
                "fullscreen": false,
                "maximized": true,
                "visible": true
            }
        ],
        "security": {
            "csp": null
        },
        "permissions": [
            "http://localhost:8000/*",
            "http://localhost:3000/*",
            "https://dpardo-it-ticket-ai-backend.hf.space/*",
            "https://*.hf.space/*",
            "core:window:allow-create",
            "core:window:allow-close",
            "core:dialog:open"
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "android": {
            "debugApplicationIdSuffix": ".debug"
        }
    }
}
