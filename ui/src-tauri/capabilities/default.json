{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "enables the default permissions",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:window-create",
        "core:window-close",
        "core:dialog-open",
        "http://localhost:8000/*",
        "http://localhost:3000/*",
        "https://dpardo-it-ticket-ai-backend.hf.space/*",
        "https://*.hf.space/*"
    ]
}
