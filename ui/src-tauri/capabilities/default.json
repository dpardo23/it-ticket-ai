{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "enables the default permissions",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:window:allow-create",
        "core:window:allow-close",
        "core:dialog:allow-open",
        "http:allow-http://localhost:8000/*",
        "http:allow-http://localhost:3000/*",
        "http:allow-https://dpardo-it-ticket-ai-backend.hf.space/*",
        "http:allow-https://*.hf.space/*"
    ]
}
